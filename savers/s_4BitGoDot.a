
	!src <godotlib.lib>		; Label-Library einbinden
	*= $c000			; generelle Startadresse für alle Module
	!ct pet			; Texte werden in PETSCII assembliert
;	!sl "labels.txt"

; -----------------------------------------
;
; svr.4BitGoDot
;     Saver für GoDots 4Bit-Bilder
;
; 1.05: 09.03.93, slightly changed
; 1.06: 19.04.18, added: automatical file suffix
; 1.07: 13.04.26, reformatted and slightly shortened
;
; -----------------------------------------

; -------------------------------------------------------------- Label-Definitionen

	indicator		= $ad

	offx		= ls_adrmisc
	offy		= offx+1

	cnt		= $31	; /$32
	byte		= $33
	adcnt		= $3e

; -------------------------------------------------------------- Header

 	jmp start			; Jedes Modul beginnt hiermit

	!by $40
	!by 0			; Own-Requester-Flag (nur!) für Lader (4 = eigener Req)
	!by 0
	!wo modend		; Endadresse+1 des Moduls
	!wo 0			; reserviert für REU access
	!tx "4Bit GoDotFormat"
	!tx "1.07"
	!tx "13.04.26"
	!tx "A.Dettke        "

; --------------------------------------------------------------

; --------------------------------------------------------------
; -------------------------------------------------------------- These lines mandatory!
; --------------------------------------------------------------

start	ldx gr_nr		; Funktionsnummer testen:
	dex
	bne saver		; Null, dann eigentlichen Saver aufrufen

	jmp initinp	; eins, dann "Input" ausführen

; --------------------------------------------------------------
; --------------------------------------------------------------
; --------------------------------------------------------------

saver	jsr gd_sproff	; Maus aus
	lda gd_modswitch	; Speichermanagement
	pha
	lda ls_flen	; Filenamen angegeben?
	beq st1		; nein, Ende

	sta wflen		; sonst: Namenslänge merken
	jsr addsig
	lda #1		; Activity vorbereiten
	sta adcnt
	lda #200
	sta cntwert
	jsr wopen		; Schreibdatei öffnen
	bne st2		; wenn Fehler: Ende

	jsr getname	; Dateinamen retten
	ldx #12		; out 12,dr,12
	jsr ckout
	jsr gd_clrms	; init gauge
	ldx #0
	jsr tcopy

	jsr write		; write file

st2	jsr clrch		; danach Bus freigeben
	lda #12		; Datei schließen
	jsr close
	jsr err9		; Floppystatus zeigen (sehr kurz)
	bne st1		; wenn fehlerfrei:

	jsr setname	; "Image Information"-Fenster aufbereiten

st1	pla		; dann Memory Management
	sta gd_modswitch

	jsr gd_spron	; Mauszeiger wieder an
	sec		; Leave-Flag setzen
	rts		; fertig

; ---------------------------
; --------------------------- Input Routines (erforderlich!)
; ---------------------------

!src <input.inc>

; ---------------------------
; ---------------------------
; ---------------------------


; -------------------------------------------------------------------------
; -------------------------------------------------------------- Disk Access Routines
; -------------------------------------------------------------------------

god0	!tx "god0"
pw	!tx "w,p,"
sigtx	!tx "tb4."
sigtxs	!scr "tb4."
drinit	!tx "i0"
wflen	!by 0

; -------------------------------------------------------------- Filehandling

wopen	jsr inull		; Initialize
	bne err8
	ldy wflen		; ",p,w" anhängen
	ldx #3
wo1	lda pw,x
	sta ls_nambuf,y
	iny
	dex
	bpl wo1
	sty wflen
	lda #12		; OPEN 12,drive,12,"name,p,w"
	tay
	ldx ls_drive
	jsr filpar
	lda wflen
	ldx #<ls_nambuf
	ldy #>ls_nambuf
	jsr filnam
	jsr copen
	jmp err9

inull	ldx #<drinit	; Initialize Drive
	ldy #>drinit
	lda #2
	jsr gd_sendcom
err9	jsr gd_xmess
	lda ls_err2
	and #15
err8 	sec
	rts

; -------------------------------------------------------------------------
; -------------------------------------------------------------- Activity Handler
; -------------------------------------------------------------------------

messout	ldx #<message	; Textausgabe
	ldy #>message
	jmp gd_xtxout2

tcopy	ldy #0		; Informationstextauswahl (hinter Label "txt"), Offset auf Text in .x
tc0 	lda txt,x
	beq clrmess
	sta message,y
	inx
	iny
	bne tc0

action 	dec adcnt		; Activity, nur bei 0
	bne ld4
	lda cntwert	; dann: Reload des Zählers
	sta adcnt
	ldy offy		; Offset auf Balkenende
	cpy clrmess+1	; Ende erreicht?
	bne act0
	jsr clrmess	; ja, re-Init
act0	ldx offx		; Dicke des Balkenendstücks
	lda filltab,x
	sta mess,y
	jsr messout	; Balken ausgeben
	dec offx		; Endstück nächstes Mal dicker
	bpl ld4		; bis gefüllt
	inc offy		; dann Balken selbst verlängern
	lda #7		; Endstück wieder dünn
	sta offx
ld4 	rts

clrmess	ldx #23		; Puffer für Balken löschen
	lda #32
cl0	sta mess,x
	dex
	bpl cl0
	ldy #0		; Balkenlänge 0
	ldx #7		; Dicke am Ende 0
	sty offy
	stx offx
	rts

filltab	!by 160,93,103,127,126,124,105,109
cntwert	!by 50
txt	!scr " Bitmap ",0	; Offset: 0 (Länge hier: 8, kein weiterer Text)
message	!fill 8,32	; 8 Zeichen für Infotext
mess	!fill 24,32	; 24 Zeichen für Fortschrittsbalken, Länge von message und mess zusammen 32
	!by 0		; bei Änderung von 24: "clrmess" anpassen (dort Wert minus 1)!

; -------------------------------------------------------------------------
; -------------------------------------------------------------- Image Info Handler
; -------------------------------------------------------------------------

getname	ldx #0		; aktuellen Filenamen sichern
si0	lda ls_lastname,x
	beq si1
	sta nbuf,x
	inx
	cpx #16
	bcc si0
si1	rts

setname	lda #0		; Namen in Image Info eintragen
	ldx #<ls_picname
	ldy #>ls_picname
	stx sc_texttab
	sty sc_texttab+1
	tax
	ldy #0
si4	lda nbuf,x
	beq si5
	sta (sc_texttab),y
	inx
	iny
	bne si4
si5	rts
;
nbuf	!fill 16,32	; Transferpuffer
	!by 0

; ------------------------------------------------ Counters

cou5	inc sc_texttab	; Vorwärtszähler (Index in 4Bit)
	bne cou6
	inc sc_texttab+1
cou6	lda ls_vekta8	; Rückwärtszähler (32000 Bytes)
	bne cou7
	dec ls_vekta8+1
cou7	dec ls_vekta8
	lda ls_vekta8
	ora ls_vekta8+1
	rts

; -------------------------------------------------------------------------
; -------------------------------------------------------------- Write File
; -------------------------------------------------------------------------

write	ldx #0		; File signature "GOD0"
-	lda god0,x
	jsr bsout
	inx
	cpx #4
	bcc -

	lda #<32000	; init: count 32000 bytes
	ldx #>32000
	sta ls_vekta8
	stx ls_vekta8+1
	lda #<sy_4bit	; from $4000 (to $bd00)
	ldx #>sy_4bit
	sta sc_texttab
	stx sc_texttab+1
	sta byte		; .a=0
	sta cnt		; init pack counter
	sta cnt+1

wr0	ldy #0		; write file data
	lda (sc_texttab),y
	jsr pack
	jsr action
	jsr cou5		; count bytes
	bne wr0

	lda byte		; flush compress buffer
	eor #$ff
	jsr pack
	lda #$ad		; signature ("$ad")
	jsr bsout
	sec		; Leave-Flag
	rts		; fertig

; ------------------------------------------------ Compress

pack	cmp byte		; this byte equal to last one?
	beq incr		; yes, count
p256	pha		; no, more than 255? first: save byte
	lda cnt+1
	bne wl0
	lda cnt		; no, already 4?
	beq wl1
	cmp #4		; yes, pack it
	bcs wl0
	lda byte		; no, current byte: indicator? ($ad)
	cmp #indicator
	bne wl2		; no, write byte
wl0	lda #indicator	; yes, write pack sequence: $ad,cnt,byte
	jsr bsout
	lda cnt
	jsr bsout
	lda #1		; reset cnt
	sta cnt
	lda #0
	sta cnt+1
wl2	lda byte
	jsr bsout
	dec cnt
	bne wl2
wl1	pla		; re-get current byte
	sta byte
incr	inc cnt		; count
	bne wl3
	inc cnt+1		; 256?
wl4	jsr p256		; yes, recursion
	dec cnt		; letzten Wert ausgleichen, fertig gepackt
wl3	rts

; -------------------------------------------------------------------------
; -------------------------------------------------------------- Filenamen verlängern
; -------------------------------------------------------------------------

addsig	pha		; Länge merken
	tay
	dey
	ldx #0
ag4	lda ls_nambuf,y	; endet auf ".4bt"?
	cmp sigtx,x
	bne ag2		; nein
	dey
	inx
	cpx #4
	bcc ag4
	pla		; ja, fertig
	rts

ag2	pla
	tay		; Name länger als 12 Zeichen?
	cpy #13
	bcs ag0		; ja, behandeln

ag5	ldx #3		; nein, ".4bt" anhängen
ag1	lda sigtx,x
ag3	sta ls_nambuf,y
	lda sigtxs,x	; auch für Image Info
	sta ls_lastname,y
	iny
	dex
	bpl ag1
	sty wflen		; neue Länge merken, fertig
	sty ls_flen
	rts

ag0	dey		; auf 12 verkürzen
	cpy #12
	bne ag0
	beq ag5		; unbed. Sprung

; ------------------------------------------------

modend 	!eof
