
	!src <godotlib.lib>
	*= $c000
	!ct pet
;	!sl "labels.txt"

; ---------------------------
;
;    ldr.IFFdither
;    Lader für IFF OCS
;    bis zu einer Größe von 1024x768
;    unterstützt HAM, EHB und Interlace
;    erzeugt Multicolor-Dithering
;
;    0.99: 17.09.93, first release
;    1.00: 06.11.16, added Balancing and Level
;                    improved dithering tables at grey1 and grey2
;    1.01: 14.09.21, added: break loading process with STOP key
;    1.02: 19.03.26, added: alternative dithertype (plus gadgets to select)
;          22.03.26, added: more comments
;
; ---------------------------

; --------------------------- Equates

	shift		= $028d

	rasterize		= $33	; /$34
	red		= $35
	grn		= $36
	blu		= $37
	min		= $38
	minx		= $3a
	cmg		= $3b
	lace		= $3c
	pbuf		= $3d
	rbuf		= $3e
	pcnt		= $3f
	adcnt		= $40
	nflg		= $41
	zflg		= $42
	cgflg		= $43
	gpy		= $44
	gpx		= $46
	xbuf		= $47
	ybuf		= $48
	palcnt		= $49
	smin		= $4a
	sminx		= $4c
	patty		= $4e

	name		= $b0
	dst		= name
	spalte		= $b1
	offy		= $b2
	comp		= $b3

	dst0		= $f7
	bbuf		= $f9
	lcnt8		= $fa
	lcnt		= $fb
	bcnt		= $fc
	plmask		= $fd
	bytes		= $fe
;
	pal		= $3f40
	hdbuf		= modend
	planes		= hdbuf+8
	rbk		= hdbuf+64
	gbk		= rbk+64
	bbk		= gbk+64
	dbuf		= $cd00
	dbuf1		= dbuf+64
	dithtab		= dbuf+192

	p0		= $bd00
	p1		= p0+128
	p2		= p1+128
	p3		= p2+128
	p4		= p3+128
	p5		= p4+128
;
;
; --------------------------- Header

header	jmp start
	!by $80
	!by 4
	!by 1			; dirty
	!wo modend
	!wo 0
	!pet "AMIGA ILBM (OCS)"
	!pet "1.02"
	!pet "19.03.26"
	!pet "W.Kling/A.Dettke"

	!pet "MaxPlanes = 6   "	; descriptional text
	!pet "MaxWidth  = 1024"
	!pet "MaxPalette= 256 "
	!pet "AutoResize= 50% "
	!pet "No AutoCenter ! "
	!pet "LookMum,NoHands!"
;
; --------------------------- Main

start	ldx #47		; retrieve current RGB palette settings from system
stt0	lda gr_rgb,x
	sta cred,x
	dex
	bpl stt0
	inx
	stx sc_stop	; init break by STOP ### 1.01

stt1	ldx used		; used is...
	beq cancel	; 0: load was cancelled
	bmi requ		; negative on start: open requester
	cpx #3		; 3: loader finished
	bcs cancel
;
	dec used		; everything else (1 or 2, dec used to 0 or 1)
	jsr getname	; save filename
	jsr gd_xopen	; open file
	jsr gd_clrms	; clear message bar

	ldx #6
cl0	lda ilbm,x	; reset message
	sta message,x
	dex
	bpl cl0
	lda #32
	ldx #24
cl	sta mess,x
	dex
	bpl cl

	lda #200		; set activity data
	sta adcnt
	lda #0
	sta offy
	jsr setdither	; set current dither type (default: oblique)

	jsr checkiff	; check if file is IFF (doesn't return on fail)

	ldy #0		; reset plane buffers (6)
	tya
clbl	sta p0,y
	sta p2,y
	sta p4,y
	iny
	bne clbl
	jsr getbody	; read image body

	lda which		; determine color mode (color or gray)
	beq cl01
	jsr getdatac	; set image info respectively
	beq cl02
cl01	jsr getdatag

cl02	jsr cancel	; reset loader management values
err	jsr gd_xclose	; close file
	lda #$03		; switch mouse pointer on (?! jsr gd_spron !?)
	sta $d015
	jsr gd_xmess	; show floppy message (for a blink)
	bcc cn2		; uncond. branch

; --------------------------- Exit Loader

cancel	lda #$ff		; SE: Leave Loader, reset used
	sta used
	lda shift		; Shift (-Lock) gedrückt?
	and #1
	bne cn2		; ja, Sprung

	ldy #16		; sonst: Balancing-Tabelle initialisieren
	sty gr_ctr
	sty gr_brt
lll	dey
	tya
	sta gr_btab,y
	bne lll

cn2	sec 		; Leave Loader to Main Screen
	rts

; --------------------------- Show Requester

requ	inc used		; used: now 0
	jsr makechr	; create listbox char
	ldx #<ifflst	; show requester
	ldy #>ifflst
	jsr gd_xmloop	; wait for mouse input
	jmp stt1		; loop back to start of loader
;
; --------------------------- Events: Color and Gray Scale

sevcol	inc used		; used: 2
sevgray   inc used		; used: 1
	ldx used
	dex
	stx which		; set as color mode
	ldx #1		; open file requester
	jsr gd_xload	; recursion: load iff file (routine from label stt1)
	lda #3		; end up here: set flag to leave loader
	sta used
	sec
	rts

; --------------------------- Event: Set Dithertype

setdither	lda dith
	bne +
	lda #<cltabn	; flag is 0: new type dither
	ldx #>cltabn
	bne ++
+	lda #<cltabo	; flag is 1: old type
	ldx #>cltabo
++	sta rasterize
	stx rasterize+1
	rts

; --------------------------- Activity (short version, deprecated)

adinc	ldy offy
	dec adcnt		; dec activity counter
	lda adcnt
	and #7		; is 0?
	bne adskip
	lda filltab	; yes, get proceed char
	sta mess,y
	inc offy
	bne messout
adskip	tax
	lda filltab,x
	sta mess,y
;
messout   ldx #<message	; advance gauge bar
	ldy #>message
	jmp gd_xtxout2
;
filltab   !by 160,93,103,127,126,124,105,109
ilbm	!scr " ILBM  "

message   !scr " ILBM  "
mess	!fill 25,32
	!by 0
;
; --------------------------- Error Messages

err1	!scr "ERROR: Width must be <1024 pxls."
err2	!scr "    ERROR: Not an IFF file.     "
err3	!scr "  ERROR: No valid IFF picture.  "
err4	!scr "    ERROR: Too many colors.     "
err5	!scr "  Loading terminated by STOP.   "

; --------------------------- Check file for IFF

checkiff  ldy #3		; read 4 bytes
il1	jsr basin
	cmp form,y	; "FORM"?
	bne faila		; no
	dey
	bpl il1
	jsr dum4		; yes, skip another 4 bytes (length)
	ldy #7		; read 7 bytes
il2	jsr basin
	cmp ilbmbmhd,y	; "ILBMBMHD"?
	bne failb		; no
	dey
	bpl il2
	jsr dum4		; yes, skip 4 bytes
	sta chl		; last byte is length (save it)
	jsr gethd		; now get complete header

	cpx #7		; in .x: amount of planes (max: 6)
	bcs faild
	lda xsize+1	; image > 1024 in width?
	beq ghs2
	cmp #>1024
	beq ghs1
	bcs failc		; yes, error
	bcc ghs2
ghs1	lda xsize
	bne failc

ghs2	lda #<cmap	; no, search for CMAP chunk
	ldx #>cmap
	jsr search
	ldx #3		; skip 3 bytes
	jsr dumx
	sta gpy+1		; amount of colors (hi)
	jsr basin
	sta gpy		; (lo)
	ora cmgfake
	sta cmgfake
	jsr chkcols
	bcs faild
	jsr setconv
	jsr getpal
	lda #<body	; search for BODY chunk
	ldx #>body
	jsr search
	jsr setcmg	; set color mode
	jsr setvmode	; set view mode
	jmp dum4		; skip 4 bytes finally
;
; --------------------------- ERROR Messages

faila	ldx #32
	!by $2c
failb	ldx #64
	!by $2c
failc	ldx #0
	!by $2c
faild	ldx #96
	!by $2c
faile	ldx #128		; break by STOP
	ldy #0
fl0	lda err1,x
	sta message,y
	inx
	iny
	cpy #32
	bne fl0
	jsr err
	jsr gd_clrms
	jsr messout
	jsr wait
	clc
	jmp fail3
;
; ----------------------------------------- Wait for Clicks

wait	lda #0
	sta sc_stop
	sta sc_keyprs
waiton	lda joy		; wait for click or STOP
	eor #$ff
	and #$10
	ora sc_keyprs
	ora sc_stop
	beq waiton
	rts

; ---------------------------

chkcols   lda gpy+1
	cmp #3
	bcc ccs2
	beq ccs1
	bcs ccs2
ccs1	lda gpy
	cmp #1
ccs2	rts
;
; --------------------------- Init distributor

setconv   ldx used
	beq il3
	lda #<assigncol
	ldy #>assigncol
	bne il4
il3	lda #<makegray
	ldy #>makegray
il4	sta convmode
	sty convmode+1
	rts
;
; --------------------------- Distributor

convcol   jmp (convmode)
;
convmode  !by 0,0

; --------------------------- Skip data bytes
;
dum4	ldx #4
dumx	jsr basin
	dex
	bne dumx
	rts
;
; --------------------------- Read Header information

gethd	ldx #0		; save header to buffer
hdloop	jsr basin
	sta hdbuf,x
	inx
	cpx chl
	bne hdloop

	lda hdbuf		; get...
	sta xsize+1	; image size: x
	lda hdbuf+1
	sta xsize
	lda hdbuf+2	; image size: y
	sta ysize+1
	lda hdbuf+3
	sta ysize
	lda #0		; preset lace mode (to off)
	sta lace
	sta lacefake
	sta cmg

	lda hdbuf+2	; determine lace mode (get hight hi)
	beq nolace
	cmp #$02		; more than 1? (yes: must be lace)
	bcs lace0
	lda hdbuf+3	; lo: more than 290? (yes: must be lace)
	cmp #$23
	bcc nolace
lace0	inc lacefake

nolace	ldx planes	; compute bytes to read in x direction (width)
	stx cmgfake
	lda pltab,x
	sta plmask
	lda xsize
	sta bytes
	lda xsize+1
	lsr
	ror bytes
	lsr
	ror bytes
	lsr
	ror bytes
	lda xsize
	and #15
	beq hds1
	inc bytes
	and #8
	bne hds1
	inc bytes

hds1	lda hdbuf+10	; get compress flag
	sta comp
	rts
;
; ---------------------------

cmgfake   !by 0
lacefake  !by 0
;
; --------------------------- Chunk Search

search	sta name		; address of chunk name
	stx name+1
searchl   lda #0
	sta okflg
	sta cgflg
	ldy #3
l6	jsr basin
	cmp (name),y	; is chunk to search for?
	beq s1
	inc okflg		; no, count misses
s1	cmp camg,y	; is it "CAMG" perhaps? (don't miss CAMG!)
	beq s11
	inc cgflg		; no, count misses
s11	dey
	bpl l6

	lda okflg		; searched chunk found?
	beq ok		; yes, leave search
	lda cgflg		; or CAMG found?
	beq getcmg	; yes, get CAMG chunk

	ldx #3		; not found any of these, skip 3 bytes
	jsr dumx
	sta chl+1		; store last retrieved value (hibyte)
	jsr basin		; store next value (lobyte)
	sta chl		; of length of current chunk (which is to skip)
	and #1		; lobyte 0?
	beq l7
	inc chl		; no, inc lo
	bne l7		; now 0?
	inc chl+1		; yes, inc hi

l7	jsr basin		; skip cureent chunk
	lda chl
	bne s2
	dec chl+1		; count length
s2	dec chl
	lda chl		; length down to 0?
	ora chl+1
	bne l7
	beq searchl	; yes, continue search for wanted chunk
ok	rts		; until found
;
; --------------------------- Get CAMG Chunk

getcmg	jsr dum4		; skip length (4 bytes)
	ldx #3		; preset viewmode
	stx cmg
	jsr dumx		; skip 3 bytes
	and #$08		; last byte (hi): 1xxx xxxx xxxx (HAM)?
	cmp #$08
	bne gcs1
	lda #54		; yes, set flag
	sta cmg
gcs1	jsr basin		; next (lo): 1xxx x1xx
	tax
	and #4		; lace?
	sta lace		; yes, set flag
	txa
	and #$80
	cmp #$80		; extra halfbrite?
	bne gcs2
	lda #102		; yes, set flag (overwriting possible HAM flag)
	sta cmg
gcs2	jmp searchl	; continue chunk search
;
; --------------------------- Read Palette Bytes

getpal	ldx #0
gpl4	ldy gpy
	jsr basin
	lsr
	lsr
	lsr
	lsr
	jsr balancing	; care for balancing
	sta red
	sta rbk,x
	dey
	beq palq
	jsr basin
	lsr
	lsr
	lsr
	lsr
	jsr balancing
	sta grn
	sta gbk,x
	dey
	beq palq
	jsr basin
	lsr
	lsr
	lsr
	lsr
	jsr balancing
	sta blu
	sta bbk,x
	sty gpy
	stx gpx
	cpx #64
	bcs fedup
	jsr convcol	; convert to c64
	ldx gpx
	sta pal,x
	tya
	sta pal+64,x
	lda patty
	sta dithtab,x	; create dither table
fedup	inx
	dec gpy
	bne gpl4
	dec gpy+1
	bpl gpl4
palq	rts
;
; ---------------------------

balancing	stx gpx		; process balancing
	tax
	lda gr_btab,x
	ldx gpx
	rts

; --------------------------- Assign Colors from RGB

assigncol lda red		; commentation: see m_DecodeGIF64c.a
	clc
	adc grn
	adc blu
	tax
	lda avr,x
	ldy #0
	cmp red
	bne as0
	iny
as0	cmp grn
	bne as1
	iny
as1	cmp blu
	bne as2
	iny
as2	cpy #2
	bcc cl51
	tax
	lda pats,x
	sta patty
	lda gray2,x
	tay
	lda cpref,y
	tay
	lda dnib,y
	tay
	lda gray1,x
	tax
	lda cpref,x
	tax
	lda dnib,x
	rts
;
cl51	ldx level		; Level
cl6	lda #0
	sta dbuf1,x
	sta nflg
	sta zflg
	lda cred,x
	sec
	sbc red
	bne rd0
	inc zflg
rd0	bcs rpos
	eor #$ff
	adc #1
	inc nflg
rpos	tay
	lda quad,y
	sta dbuf,x
	lda cgrn,x
	sec
	sbc grn
	bne gn0
	inc zflg
gn0	bcs gpos
	eor #$ff
	adc #1
	inc nflg
gpos	tay
	lda quad,y
	clc
	adc dbuf,x
	sta dbuf,x
	bcc gsk
	inc dbuf1,x
gsk	lda cblu,x
	sec
	sbc blu
	bne bl0
	inc zflg
bl0	bcs bpos
	eor #$ff
	adc #1
	inc nflg
bpos	tay
	lda nflg
	beq nopf
	clc
	adc zflg
	cmp #3
	beq nopf
	lda #2
	!by $2c
nopf	lda #0
	clc
	adc quad,y
	adc dbuf,x
	sta dbuf,x
	bcc bsk
	inc dbuf1,x
bsk	inx
	cpx #16
	bne cl6
;
	stx min+1
	ldx level
ml1	lda dbuf1,x
	tay
	cmp min+1
	beq ms1
	bcs ms2
	bcc ms3
ms1	lda dbuf,x
	cmp min
	beq ms4
	bcs ms2
ms3	lda dbuf,x
ms4	sty min+1
	sta min
	stx minx
ms2	inx
	cpx #16
	bne ml1

	lda min+1
	sta smin+1
	lda min
	sta smin
	ldy minx
	sty sminx
	lda #$ff
	sta dbuf1,y
	stx min+1
	ldx level
ms23	lda dbuf1,x
	tay
	cmp min+1
	beq ms20
	bcs ms21
	bcc ms22
ms20	lda dbuf,x
	cmp min
	beq ms24
	bcs ms21
ms22	lda dbuf,x
ms24	sty min+1
	sta min
	stx minx
ms21	inx
	cpx #16
	bne ms23
	lda smin
	ora smin+1
	beq ms27
	lda smin
	clc
	adc min
	sta sminx+1
	lda smin+1
	adc min+1
	sta patty
	ldx #4
ms25	asl min
	rol min+1
	dex
	bne ms25
	ldx #0
ms26	lda min
	sec
	sbc sminx+1
	sta min
	lda min+1
	sbc patty
	bmi ms27
	sta min+1
	inx
	bne ms26
ms27	stx patty
	lda sminx
	tax
	lda cpref,x
	tax
	lda dnib,x
	tay
	lda minx
	tax
	lda cpref,x
	tax
	lda dnib,x
	rts
;
; ---------------------------

avr	!by 0,0,1,1,1,2,2,2
	!by 3,3,3,4,4,4,5,5,5
	!by 6,6,6,7,7,7,8,8,8
	!by 9,9,9,10,10,10
	!by 11,11,11,12,12,12
	!by 13,13,13,14,14,14
	!by 15,15
;
; ---------------------------

quad	!by 0,1,4,9,16,25,36,49,64,81,100,121,144,169,196,225
;
; ---------------------------

cred	!by 11,7,3,0,15
	!by 06,15,13,12,10,08
	!by 00,00,00,10,14

cgrn	!by 11,7,3,0,15
	!by 04,07,08,04,15,00
	!by 08,00,12,15,14

cblu	!by 11,7,3,0,15
	!by 00,07,05,12,14,00
	!by 15,10,05,06,07

cpref	!by 11,7,3,0,15
	!by 2,9,6,5,12,4
	!by 8,1,10,14,13

gray1	!by 3,3,2,2,2,2,1,1,1,1,0,0,0,0,4,4
gray2	!by 2,2,2,1,1,1,1,0,0,0,0,4,4,4,4,4

pats	!by $00,$04,$07,$0b,$00,$04,$07,$0b
	!by $00,$04,$07,$0b,$00,$05,$0a,$10

; --------------------------- Colors

setcmg	lda cmg		; .x=0
	bne scs0
	lda cmgfake	; contains number of planes
	sta cmg
	lda lacefake	; must be lace: if >0
	sta lace
scs0	lda cmg
	cmp #102		; extra half brite?
	bne scs1		; no, leave

	ldx #31		; yes, .x=31
	ldy used		; get mode (gray or color)
	beq scl2

scl1	lda rbk,x		; gray: get palette from file
	lsr
	sta red
	lda gbk,x
	lsr
	sta grn
	lda bbk,x
	lsr
	sta blu
	stx gpx
	jsr convcol	; convert to 4Bit
	ldx gpx
	sta pal+32,x	; and store values
	tya
	sta pal+96,x
	lda rbuf
	sta dithtab+32,x
	dex
	bpl scl1
scs1	rts

scl2	lda pal+64,x	; color: get balanced stored palette
	and #15
	lsr
	tay
	lda dnib,y	; produce 4bit double nibbles
	sta pal+96,x	; and store
	dey
	bpl scl3		; don't use <0
	iny
scl3	lda dnib,y
	sta pal+32,x
	lda dithtab,x	; double the table (for EHB)
	sta dithtab+32,x
	dex
	bpl scl2
	rts

; --------------------------- Viewmode

setvmode  ldx planes	; set view mode, get amount of planes
	dex
	lda cmg
	cmp #54		; HAM?
	bne svms1
	ldx #7		; yes, 6 planes
svms1	cmp #102		; lace?
	bne svms2
	inx		; yes
svms2	txa		; no
	asl
	asl
	tax
	ldy #3
svml	lda vmodes,x	; show info text
	sta viewmode+3,y
	inx
	dey
	bpl svml
	sty palcnt
	lda ysize
	bne nopal
	lda ysize+1
	cmp #3
	bcs nopal
	lda #4
	sta palcnt
nopal	rts
;
vmodes	!pet "  2   4   8  61  23  46 bhe mah "
;
; --------------------------- Read one Pixel Line

readline  lda #<p0		; to plane buffer 0
	ldx #>p0
	sta pbuf		; .a=0
	stx pbuf+1
	sta red		; init colors
	sta grn
	sta blu
	lda planes
	sta pcnt

nline	ldy #0
	ldx sc_stop	; STOP pressed?	### 1.01
	bne jfaile
	lda comp		; compressed?
	beq uncomp	; no, read uncompressed data

next	jsr basin		; yes, decompress
	tax
	bmi decomp
rll	jsr basin
	sta (pbuf),y
	iny
	dex
	bpl rll
	bmi rls

; --------------------------- Decompress

decomp	dex
	jsr basin
rll1	sta (pbuf),y
	iny
	inx
	bne rll1
rls	cpy bytes		; until width
	bcc next
	bcs rls1
;
; --------------------------- read uncompressed part

uncomp	jsr basin
	bcs fail2
	sta (pbuf),y
	iny
	cpy bytes
	bcc uncomp
rls1	lda pbuf
	clc
	adc #128
	sta pbuf
	bcc rls2
	inc pbuf+1
rls2	dec pcnt
	bne nline
	lda xsize+1	; must image be scaled down?
	lsr
	bne squeeze	; yes, go there
	rts
;
; --------------------------- Errors

jfaile	jmp faile

fail2	pla
	pla
fail3	pla
	pla
	inc used
	rts
;
; --------------------------- Scale down files >320x200

squeeze   lda #<p0		; get data from plane buffer 0
	ldx #>p0
	sta pbuf
	stx pbuf+1
	lda planes
	sta pcnt

sql0	ldx #0
	ldy #0
sql1	lda (pbuf),y	; get plane data, shift into bbuf
	asl
	rol bbuf
	asl		; skip one bit
	asl
	rol bbuf
	asl		; skip one bit
	asl
	rol bbuf
	asl		; skip one bit
	asl
	rol bbuf
	asl		; skip one bit (now 8 bits squeezed to 4)
	sta (pbuf),y	; store back 0

	iny		; get next plane byte
	lda (pbuf),y
	asl		; shift again into bbuf (thus squeezing 16 to 8)
	rol bbuf
	asl		; see above
	asl
	rol bbuf
	asl
	asl
	rol bbuf
	asl
	asl
	rol bbuf
	asl
	sta (pbuf),y

	sty ybuf		; index merken
	txa		; .y to 0
	tay
	lda bbuf		; write squeezed value
	sta (pbuf),y
	inx
	ldy ybuf

	iny
	cpy bytes		; until width
	bne sql1

	lda pbuf		; advance to next plane
	clc
	adc #128
	sta pbuf
	bcc sqs1
	inc pbuf+1
sqs1	dec pcnt		; dec plane counter
	bne sql0		; process next plane
	rts
;
; ---------------------------

pltab	!by 0,1,3,7,15,31,63
;
dnib	!by $00,$11,$22,$33
	!by $44,$55,$66,$77
	!by $88,$99,$aa,$bb
	!by $cc,$dd,$ee,$ff,$bb
;
; --------------------------- Convert to Gray values

makegray	ldy red		; average the three values of RGB
	lda rtab,y
	clc
	ldy grn
	adc gtab,y
	ldy blu
	adc btab,y
	tay
	and #$0f
	sta rbuf
	tya
	lsr
	lsr
	lsr
	lsr
	tax
	lda dnib,x	; return same double nibble in .a and .y
	inx
	ldy dnib,x
	rts

; --------------------------- Read IFF Body Chunk (Bitmap Pixels)

getbody   lda cmg
	cmp #54		; HAM?
	bne noham3
	jmp getham	; yes, other routine

noham3	lda #<$4000	; no, set start of 4Bit data
	ldx #>$4000
	sta dst0
	sta dst
	stx dst0+1
	stx dst+1

	lda #25		; count 25 block rows
	sta lcnt8

lnloop8   lda #7		; count 7 rasterlines (tile height)
	sta lcnt

lnloop	jsr adinc		; activity
	jsr readline	; read 1 rasterline
	ldx lace		; lace?
	beq lcs0
	jsr readline	; yes, read 1 more rasterline
lcs0	dec palcnt
	bne lcs01
	lda #4
	sta palcnt
	jsr readline
	ldx lace
	beq lcs01
	jsr readline

lcs01	ldx #0
byloop	lda #3		; counts 4 (4bit) pixels
	sta bcnt
btloop	asl p5,x		; gather from planes
	rol
	asl p4,x
	rol
	asl p3,x
	rol
	asl p2,x
	rol
	asl p1,x
	rol
	asl p0,x
	rol
	and plmask	; delimit to amount of colors in file
	jsr raster	; rasterize pixel
	and #$f0
	sta bbuf		; store result as left (4bit) pixel
	asl p5,x		; now for the right pixel: gather
	rol
	asl p4,x
	rol
	asl p3,x
	rol
	asl p2,x
	rol
	asl p1,x
	rol
	asl p0,x
	rol
	and plmask	; delimit
	jsr raster	; rasterize pixel
	and #$0f
	ora bbuf		; combine result w/ left pixel
	ldy #0
	sta (dst),y	; store to 4bit bitmap
	inc dst
	bne s3
	inc dst+1
s3	dec bcnt		; count pixels
	bpl btloop
	lda dst		; proceed to next tile
	clc
	adc #28
	sta dst
	bcc s4
	inc dst+1
s4	inx		; until 40 (then rasterline is processed)
	cpx #40
	bne byloop

	lda dst0		; add 4 to address next rasterline
	clc
	adc #4
	sta dst0
	sta dst
	bcc s5
	inc dst0+1
s5	lda dst0+1
	sta dst+1
	dec lcnt		; count rasterlines (8)
	bmi rdy
	jmp lnloop
rdy	lda dst0		; then address next block row
	clc
	adc #<1248
	sta dst0
	sta dst
	lda dst0+1
	adc #>1248
	sta dst0+1
	sta dst+1
	dec lcnt8		; count block rows
	beq rdy1
	jmp lnloop8	; and loop
rdy1	rts		; until finished
;
raster 	sta ybuf		; rasterize colors: save pixel (in .a)
	lda lcnt		; which rasterline? (0..7, times 4, lower 4 bits)
	asl
	asl
	and #15
	ora bcnt		; combine with pixel number (0..3)
	tay
	lda (rasterize),y	; fetch a pattern (from cltabo/n below)
	ldy ybuf		; get pixel as index into compare table
	cmp dithtab,y
	beq s6
	bcc s6
	lda pal,y		; and finally return rasterized value
	rts
s6	lda pal+64,y
	rts

; ---------------------------

cltabo 	!by $10,$08,$0e,$06		; old pattern (vertical)
	!by $04,$0c,$02,$0a
	!by $0d,$05,$0f,$07
	!by $01,$09,$03,$0b

cltabn	!by $0d,$08,$0e,$06		; new pattern (oblique)
	!by $07,$0f,$05,$0c
	!by $10,$04,$0b,$02
	!by $03,$0a,$01,$09

rtab 	!by $00,$05,$0a,$0f,$13,$18,$1d,$22
	!by $26,$2b,$30,$35,$3a,$3e,$43,$48
gtab 	!by $00,$09,$13,$1c,$26,$2f,$39,$42
	!by $4c,$55,$5e,$68,$71,$7b,$84,$8e
btab 	!by $00,$02,$03,$05,$07,$09,$0a,$0c
	!by $0e,$10,$12,$13,$15,$17,$19,$1a

; --------------------------- Read HAM image data

getham	lda #<$4000	; set start of 4Bit data
	ldx #>$4000
	sta dst0
	sta dst
	stx dst0+1
	stx dst+1

	lda #25		; count 25 block rows
	sta lcnt8
hlnloop8  lda #7		; count 7 rasterlines (tile height)
	sta lcnt
hlnloop   jsr adinc		; activity
	jsr readline	; read 1 rasterline
	ldx lace		; lace?
	beq lcs1
	jsr readline	; yes, read 1 more rasterline
lcs1	dec palcnt
	bne lcs11
	lda #4
	sta palcnt
	jsr readline
	lda lace
	beq lcs11
	jsr readline

lcs11	ldx #0
hbyloop   lda #3		; counts 4 (4bit) pixels
	sta bcnt
hbtloop   asl p3,x		; gather pixels from planes (in HAM mode, left pixel)
	rol
	asl p2,x
	rol
	asl p1,x
	rol
	asl p0,x
	rol
	and #$0f
	tay
	asl p5,x
	rol
	asl p4,x
	rol
	and #3
	beq pure
	stx xbuf

	eor #$02		; HAM stuff
	cmp #$03
	bne hs1
	and #$02
hs1	tax
	sty red,x
	jsr convcol	; convert colors to 4bit
	sta pal+16
	sty pal+80
	lda rbuf
	sta dithtab+16
	ldx xbuf
	lda #$10		; and rasterize
	bpl pr1

pure	lda rbk,y		; normal color (not HAMmed)
	sta red
	lda gbk,y
	sta grn
	lda bbk,y
	sta blu
pr1	jsr raster	; rasterize
;
hok	and #$f0		; store result (left part of double nibble)
	sta bbuf
	asl p3,x		; now for right pixel
	rol
	asl p2,x
	rol
	asl p1,x
	rol
	asl p0,x
	rol
	and #$0f
	tay
	asl p5,x
	rol
	asl p4,x
	rol
	and #3
	beq pure1

	stx xbuf
	eor #$02
	cmp #$03
	bne hs2
	and #$02
hs2	tax
	sty red,x
	jsr convcol
	sta pal+16
	sty pal+80
	lda rbuf
	sta dithtab+16
	ldx xbuf
	lda #$10
	bpl pr2

pure1	lda rbk,y		; unHAMmed pixels
	sta red
	lda gbk,y
	sta grn
	lda bbk,y
	sta blu
pr2	jsr raster
;
hok1	and #$0f
	ora bbuf
	ldy #0
	sta (dst),y
	inc dst
	bne hs3
	inc dst+1
hs3	dec bcnt		; count pixels (0..3)
	bmi hs31
	jmp hbtloop

hs31	lda dst		; next tile (in 4bit)
	clc
	adc #28
	sta dst
	bcc hs4
	inc dst+1
hs4	inx		; count width (40 tiles)
	cpx #40
	beq hs41
	jmp hbyloop

hs41	lda dst0		; address next rasterline
	clc
	adc #4
	sta dst0
	sta dst
	bcc hs5
	inc dst0+1
hs5	lda dst0+1
	sta dst+1
	dec lcnt		; count rasterlines (0..7)
	bmi hrdy
	jmp hlnloop

hrdy	lda dst0		; address next block row
	clc
	adc #<1248
	sta dst0
	sta dst
	lda dst0+1
	adc #>1248
	sta dst0+1
	sta dst+1
	dec lcnt8		; count block rows (1..25)
	beq hrdy1
	jmp hlnloop8
hrdy1	rts		; until finished
;
; --------------------------- Data

form	!pet "mrof"
ilbmbmhd  !pet "dhmbmbli"
cmap	!pet "pamc"
camg	!pet "gmac"
body	!pet "ydob"
xsize	!by 0,0
ysize	!by 0,0
okflg	!by 0
chl	!by 0,0
;
used	!by $ff
which	!by 0
level	!by 3
lvlnum	!pet "012345"
dith	!by 0
doffs	!by 3,7
dithtype	!scr "OblqVert"
chschr	!by $00,$3a,$46,$4e,$40,$40,$3c,$00

; --------------------------- Screenlist

ifflst	!by 0
	!by 6,11,18,13,$81
	!wo 0
	!scr "Load IFF dith",0
	!by 10,11,18,3,$ca
	!wo sevgray
	!scr "Gray Scale",0
	!by 12,11,11,3,$c8
	!wo sevcol
	!scr "Color",0
lvlgad	!by 12,22,7,3,$ce
	!wo sevlvl
	!scr $df,"Lvl"
lvltx	!scr "3",0
dithgad	!by 14,22,7,3,$ce
	!wo evdither
	!by $df
dithtx	!scr"Oblq",0
	!by 16,11,18,3,$cb
	!wo cn2
	!scr "Cancel Load",0
	!by $c0,8,14,10
	!scr "Convert to",0
	!by $c0,14,13,7
	!scr "Dither:",0
	!by $80
;
; --------------------------- Event: Set Level

sevlvl	lda spalte	; where clicked? (column)
	cmp #25
	bcs lvlinc
lvldec	dec level		; left of 25: dec level
	bpl lvl0
	lda #4
	sta level
lvlinc	inc level		; right of 24: inc level
lvl0	ldx level
	cpx #6
	bcc lvl1
	ldx #0
	stx level
lvl1	lda lvlnum,x
	sta lvltx
	jsr gettab1	; show
	bcc ++

; --------------------------- Event: Set Dither Type

evdither	ldy dith		; current dither type?
	beq +
	ldy #$ff		; if 1: set to 0
+	iny		; if 0: inc to 1
	sty dith
	ldx doffs,y
	ldy #3
-	lda dithtype,x
	sta dithtx,y
	dex
	dey
	bpl -
	jsr gettab2
++	ldy #6		; show
	jmp gd_xtxout1

; --------------------------- Kringel definieren

makechr	ldx #7		; create listbox char
-	lda chschr,x
	sta sc_undochar,x
	dex
	bpl -
	rts

; --------------------------- Text output management

gettab2	lda #<dithgad	; show contents of dither gadget
	sta sc_screentab
	lda #>dithgad
	bne +
gettab1	lda #<lvlgad	; show contents of level gadget
	sta sc_screentab
	lda #>lvlgad
+	sta sc_screentab+1
	lda #0
	tax
	tay
gt0	jsr gd_setpos
	cpx #3
	bne gt0
	stx sc_ho
	jsr gd_trim
	jmp gd_initmove
;
; --------------------------- file info management

getname   ldx #0		; save name of chosen file for image info
si0	lda ls_lastname,x
	beq si1
	sta nbuf,x
	inx
	cpx #16
	bcc si0
si1	rts
;
getdatac  ldx #4		; set data for image info
	!by $2c
getdatag  ldx #9
	ldy #4
sinfo0	lda dtextc,x
	sta datatype,y
	dex
	dey
	bpl sinfo0
	jsr setname
	jsr setloader
	jsr setmode
	jmp setdata
;
setname   lda #0
	ldx #<ls_picname
	ldy #>ls_picname
	bne si3
setloader lda #17
	ldx #<ls_iloader
	ldy #>ls_iloader
	bne si3
setmode   lda #25
	ldx #<ls_imode
	ldy #>ls_imode
	bne si3
setdata   lda #33
	ldx #<ls_idrive
	ldy #>ls_idrive
si3	stx sc_texttab
	sty sc_texttab+1
	tax
	ldy #0
si4	lda nbuf,x
	beq si5
	sta (sc_texttab),y
	inx
	iny
	bne si4
si5	rts
;
nbuf	!fill 16,32
	!by 0
viewmode  !scr "IFFdith",0
modetx	!scr "160x200",0
datatype  !scr "Color",0

dtextc	!scr "Color"
dtextg	!scr "Gray "
modend	!eof

