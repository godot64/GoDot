	!src <godotlib.lib>
	!cpu m65
	*= $c000
	!ct pet
; -----------------------------------------
;
;  mod.M65.Render
;   Module to render GoDot 4Bit data to Mega65 (True Hires / True Colors)
;
;  1.00, 01.05.26, first release
;  1.01, 21.05.26, added: FCM (up to 136 colors on screen)
;  1.02, 23.06.26, changed: leave modifier *only* when hitting LEAVE
;
; -----------------------------------------

; ----------------------------------------- Equates

	screen	= $30	; /..$33
	scrram	= $34	; /$35
	cnt500	= $36	; /$37
	src1	= $38	; /$39
	vector	= $3a	; /$3b
	palette	= $3c	; /$3d

	bcode	= $1000	; bcode=$40000/$40

	mswitch	= $d02f
	scrnptr	= $d060	; /..$d063
	rgb65	= $d100

; ----------------------------------------- Header

header	jmp start
	!by $20		; = this is a modifier
	!by 0
	!by 0
	!wo modend
	!wo 0
	!tx "M65 Render Image"
	!tx "1.02"
	!tx "23.06.26"
	!tx "A.Dettke        "

; ----------------------------------------- Main

start	lda sy_mega65	; check Mega65 flag
	bne +
	ldx #<nomegalst	; when 0: C64 (fail)
	ldy #>nomegalst
	jsr gd_screen
	beq ++		; finish modifier

+	lda sc_screenvek	; save vector to main screen
	ldx sc_screenvek+1
	sta mainlst
	stx mainlst+1
reenter	ldx #<mrendlst	; go: build requester
	ldy #>mrendlst
	jsr gd_screen	; returns .a=0

++	jmp gd_eloop	; now wait for gadget clicks

; --------------------------------------- Activate VIC IV

vic4on	lda #$47		; "G"(ardner), Switch to VIC-IV mode.
	sta mswitch
	lda #$53		; "S"(tephens)
	sta mswitch
	rts

; --------------------------------------- Init Display

setscreen	ldx #0

	lda $d05d
	jsr savevals
	lda #%10000000	; $80, Disable hotregs
	trb $d05d

	lda $d04c
	jsr savevals
	lda #80		; Ensure textxpos is 80
	sta $d04c

	lda $d031
	jsr savevals
	lda #%10100000	; Disable attr; select 40-column mode (h640=0)
	trb $d031

	lda $d054
	jsr savevals
	lda #%00000101	; Enable SEAM (chr16); enable fclrhi
	tsb $d054

	lda $d058
	jsr savevals
	lda mode		; linestep = 40 x 2 /20 x 2
	sta $d058
	lda $d059
	jsr savevals
	lda #0
	sta $d059

	lda $d05e
	jsr savevals
	lda #40		; chrcount = 40
	sta $d05e

	ldy #0		; save current scrnptr
-	lda $d060,y
	jsr savevals
	iny
	cpy #4
	bcc -
	dey
	lda #0		; set scrnptr to $5.0000
-	sta scrnptr,y	; for Mega65
	dey
	bpl -
	ldy #5		; bank of "cset" data ($05)
	sty scrnptr+2	; for Mega65
	sta $d020		; Set border and background colors to blk
	sta $d021
	rts

savevals	sta preset,x
	inx
	rts

; --------------------------------------- Re-Init Standard Screen

unset	ldx #0
	jsr restore	; hotregs
	sta $d05d
	jsr restore	; textpos
	sta $d04c
	jsr restore	; attr./40 columns
	sta $d031
	jsr restore	; SEAM
	sta $d054
	jsr restore	; linestep lo
	sta $d058
	jsr restore	; hi
	sta $d059
	jsr restore	; chrcount
	sta $d05e

	ldy #0
-	jsr restore	; scrnptr (4 bytes)
	sta $d060,x
	iny
	cpy #4
	bcc -

	jsr resetspd
	lda #0		; switch back to VIC-II mode.
	sta mswitch
	sta mswitch
	lda #$12
	sta $d018

	lda sc_maincolor	; Set background and border to GoDot
	sta $d021
	sta $d020
	rts		; here: .c is set

restore	lda preset,x
	inx
	rts

; ----------------------------------------- Clear Main Screen

clrscreen sta $d707		; inline DMA
	!by 0,3,$e8,$03,32,0,0,$00,$04,0,0,0,0
	jmp resetspd

; --------------------------------------- Event: Render True Hires

evtrhires	lda #40		; set linestep to 20 x 2
	sta mode

	jsr trans4bit	; convert 4Bit to Mega65
	jsr colors
	jsr setscreen	; NCM einschalten
	jsr wait
	jsr clrscreen	; GoDot-Screen lĂ¶schen
	jmp +		; Mega65 auf Standard-Textmodus

; --------------------------------------- Event: Render True Multicolor

evtrmulti	lda #80		; set linestep to 40 x 2
	sta mode

	jsr vic4on	; VIC IV einschalten
	jsr setspeed	; 40 MHz einschalten

	jsr setcopy	; Zeiger setzen
	ldy #0		; activate IFLI palette (136 Farben):
	ldx #2
-	lda (src1),y	; save current palette to palbuffer
	sta (vector),y
	lda (palette),y	; and overwrite $d100 w/ IFLI palette
	sta (src1),y
	iny
	bne -
	inc src1+1
	inc vector+1
	inc palette+1
	dex
	bpl -

	jsr trans8bit	; Bild aufbauen
	jsr colors	; Farb-RAM fĂĽllen
	jsr setscreen	; FCM einschalten
	jsr wait		; Warten auf Taste
	jsr clrscreen	; GoDot-Screen lĂ¶schen

	jsr recopy	; Zeiger setzen
	ldy #0		; re-activate standard palette:
	ldx #2
-	lda (vector),y	; copy palbuffer
	sta (src1),y	; to $d100
	iny
	bne -
	inc src1+1
	inc vector+1
	dex
	bpl -

+	jsr unset		; Mega65 auf Standard-Screen zurĂĽcksetzen
	ldx mainlst	; ### 1.02
	ldy mainlst+1
	jsr gd_screen
	jmp reenter

; --------------------------------------- Event: Leave Modifier

evleave	sec		; no, leave modifier
	rts

; -------------------------------------- Set Copy Vectors

setcopy	lda #<iflipal	; 256 rgb values from here
	ldx #>iflipal
	sta palette
	stx palette+1
recopy	lda #<palbuffer	; here in mod
	ldx #>palbuffer
	sta vector
	stx vector+1
	lda #<rgb65	; to/from $d100
	ldx #>rgb65
	sta src1
	stx src1+1
	rts

; -------------------------------------- Event: Toggle Speed

setspeed	lda $d054		; 40 MHz einschalten
	sta speedis
	bit $d054
	bvs +
	lda #$40
	ora $d031
	sta $d031
	lda #$40
	ora $d054
	sta $d054
+	rts

resetspd	bit speedis	; und wieder ausschalten
	bvs +
	lda #%10111111
	and $d031
	sta $d031
	lda #%10111111
	and $d054
	sta $d054
+	rts

; --------------------------------------- Distribute per Vector

transport	jmp (vector)

; --------------------------------------- Distribute 4Bit Pixels and convert Colors

d_4bit	ldy #0		; fĂĽr NCM:
-	lda (src1),y
	tax		; .x als Index in Lookup Table
	lda inverted,x	; Nibbles invertieren und Farbe setzen
	sta [screen],z	; straight nach Target: $4.0000 (00 00 04 00)
	inc screen	; Target immer um 1 erhĂ¶hen
	bne +
	inc screen+1
+	iny
	cpy #4
	bcc -
	rts

; ----------------------------------------- Distribute 8Bit Double Bytes

d_8bit	ldy #0		; fĂĽr FCM:
-	lda (src1),y	; Byte holen (C64-Doppelpixel = 1 Mega65-Pixel)
	sta [screen],z	; Byte eintragen
	inc screen	; Target ($04.0000) immer um 1 erhĂ¶hen
	bne +
	inc screen+1
+	sta [screen],z	; Byte nochmal eintragen
	inc screen	; (Mega65-Doppelpixel)
	bne +
	inc screen+1
+	iny		; nĂ¤chstes Byte (4 Doppelpixel)
	cpy #4
	bcc -
	rts

; --------------------------------------- Transport 4Bit Hires to Mega65

trans4bit	lda #<d_4bit	; NCM
	ldx #>d_4bit
	sta vector
	stx vector+1

	jsr vic4on
	jsr setspeed
	lda #8		; set NCM bit
	sta ncmbit

	ldx #3		; set target to $04.0000 (in $30..$33)
	lda #0
	sta src1
-	sta screen,x
	dex
	bpl -
	ldx #4
	stx screen+2

	ldz #0		; .z: Far-Zeiger-Index (immer 0)
	lda #<sy_4bit	; 4Bit als "Zeichensatz" in den Mega65 kopieren
	ldx #>sy_4bit

-	sta src1		; Zeiger auf Source setzen (4Bit)
	stx src1+1

	jsr transport	; 4 Bytes (8 linke Pixel) ĂĽbertragen
	lda src1
	pha
	ora #$20
	sta src1
	jsr transport	; jetzt die 8 rechten Pixel daneben
	pla

	clc		; Source um 4 Bytes weiterrĂĽcken
	adc #4		; im linken Char
	sta src1
	bcc +
	inc src1+1
+	lda src1
	tax
	and #$20
	beq +
	txa
	clc		; im rechten Char
	adc #$20
	sta src1
	bcc +
	inc src1+1
+	lda src1
	ldx src1+1
	cpx #$bd		; bis $bd00 erreicht (32000 Bytes 4Bit fertig)
	bne -
	rts

; --------------------------------------- Transport 4Bit IFLI to Mega65

trans8bit	lda #<d_8bit	; FCM
	ldx #>d_8bit
	sta vector
	stx vector+1

	lda #0		; set FCM bit (unset NCM)
	sta ncmbit

	ldx #3		; set target to $04.0000 (in $30..$33)
	sta src1
-	sta screen,x
	dex
	bpl -
	ldx #4
	stx screen+2

	ldz #0		; .z: Far-Zeiger-Index (immer 0)
	lda #<sy_4bit	; 4Bit als "Zeichensatz" in den Mega65 kopieren
	ldx #>sy_4bit

-	sta src1		; Zeiger auf Source setzen (4Bit: $4000)
	stx src1+1

	jsr transport	; 4 Bytes (4 Doppelpixel) ĂĽbertragen

	lda src1
	clc		; Source um 4 Bytes weiterrĂĽcken
	adc #4
	sta src1
	bcc +
	inc src1+1
+	lda src1
	ldx src1+1
	cpx #$bd		; bis $bd00 erreicht (32000 Bytes durch: 4Bit fertig)
	bne -
	rts

; --------------------------------------- Set Color RAM

colors	lda mode		; now for the colors
	cmp #80
	bcs +
	lda #$0f		; NCM: individual foreground color
	!by $2c
+	lda #$ff		; FCM: dito
	sta foregrnd

	stz screen
	stz screen+1
	lda #$f8		; .z=0, writes 1000 double colors (of 64 bytes each)
	sta screen+2	; (2000 bytes)
	lda #$0f		; to $ff80000
	sta screen+3
loop2	lda ncmbit	; NCM bit setzen (lĂ¶schen bei FCM)
	sta [screen],z
	lda foregrnd
	inz
	sta [screen],z	; Palettenindex: 0
	inz
	bne loop2
	inc screen+1
	lda screen+1
	cmp #$08
	bcc loop2

	ldz #0
	stz screen+3	; .z=0
	lda #5		; init screen to $5.0000
	sta screen+2
	stz screen+1
	stz screen+0
	stz cnt500
	stz cnt500+1
	lda #<bcode	; init bcode vectors to $1000 (points to $4.0000)
	sta scrram
	lda #>bcode
	sta scrram+1

loop3	lda scrram
	sta [screen],z
	lda scrram+1
	inw screen
	sta [screen],z
	inw screen
	inc cnt500
	bne +
	inc cnt500+1

+	inc scrram
	bne +
	inc scrram+1
+	lda cnt500
	lda cnt500+1
	cmp #>2049
	bcc loop3
	cmp #<2049
	bcc loop3

	rts

; ----------------------------------------- Wait for Clicks

wait	lda #0
	sta sc_stop
	sta sc_keyprs
waiton	lda joy		; wait for click or STOP
	eor #$ff
	and #$10
	ora sc_keyprs
	ora sc_stop
	beq waiton
	rts

; --------------------------------------- Data

preset	!fill 11
mode	!by 0
speedis	!by 0
ncmbit	!by 0
foregrnd	!by 0
commodore	!by 0
mainlst	!wo 0

; --------------------------------------- Inverted Color Nibbles for NCM
; invert a byte value nibblewise by just using its value: ldx byte, lda inverted,x

inverted	!by $00,$60,$90,$b0,$20,$40,$80,$c0,$e0,$a0,$50,$f0,$30,$70,$d0,$10
	!by $06,$66,$96,$b6,$26,$46,$86,$c6,$e6,$a6,$56,$f6,$36,$76,$d6,$16
	!by $09,$69,$99,$b9,$29,$49,$89,$c9,$e9,$a9,$59,$f9,$39,$79,$d9,$19
	!by $0b,$6b,$9b,$bb,$2b,$4b,$8b,$cb,$eb,$ab,$5b,$fb,$3b,$7b,$db,$1b
	!by $02,$62,$92,$b2,$22,$42,$82,$c2,$e2,$a2,$52,$f2,$32,$72,$d2,$12
	!by $04,$64,$94,$b4,$24,$44,$84,$c4,$e4,$a4,$54,$f4,$34,$74,$d4,$14
	!by $08,$68,$98,$b8,$28,$48,$88,$c8,$e8,$a8,$58,$f8,$38,$78,$d8,$18
	!by $0c,$6c,$9c,$bc,$2c,$4c,$8c,$cc,$ec,$ac,$5c,$fc,$3c,$7c,$dc,$1c
	!by $0e,$6e,$9e,$be,$2e,$4e,$8e,$ce,$ee,$ae,$5e,$fe,$3e,$7e,$de,$1e
	!by $0a,$6a,$9a,$ba,$2a,$4a,$8a,$ca,$ea,$aa,$5a,$fa,$3a,$7a,$da,$1a
	!by $05,$65,$95,$b5,$25,$45,$85,$c5,$e5,$a5,$55,$f5,$35,$75,$d5,$15
	!by $0f,$6f,$9f,$bf,$2f,$4f,$8f,$cf,$ef,$af,$5f,$ff,$3f,$7f,$df,$1f
	!by $03,$63,$93,$b3,$23,$43,$83,$c3,$e3,$a3,$53,$f3,$33,$73,$d3,$13
	!by $07,$67,$97,$b7,$27,$47,$87,$c7,$e7,$a7,$57,$f7,$37,$77,$d7,$17
	!by $0d,$6d,$9d,$bd,$2d,$4d,$8d,$cd,$ed,$ad,$5d,$fd,$3d,$7d,$dd,$1d
	!by $01,$61,$91,$b1,$21,$41,$81,$c1,$e1,$a1,$51,$f1,$31,$71,$d1,$11


; --------------------------------------- RGB values of 136 IFLI colors for FCM
; 136 colors diagonally mirrored, so indeces can go from 0 to 255,
; the values are nibble-exchanged (!)

iflipal	!by $00,$91,$92,$72,$64,$74,$74,$b3,$53,$e5,$52,$15,$33,$66,$64,$f7
	!by $91,$23,$24,$04,$f5,$06,$06,$45,$e4,$77,$e3,$a6,$c4,$f7,$f5,$89
	!by $92,$24,$35,$05,$f6,$07,$17,$46,$f5,$88,$e4,$b7,$c5,$09,$f6,$8a
	!by $72,$04,$05,$e4,$d6,$e6,$e6,$26,$c5,$58,$c4,$87,$a5,$d8,$d6,$6a
	!by $64,$f5,$f6,$d6,$c8,$d8,$d8,$18,$b7,$4a,$b6,$79,$97,$ca,$c8,$5c
	!by $74,$06,$07,$e6,$d8,$e8,$e8,$28,$c7,$5a,$c6,$89,$a7,$da,$d8,$6c
	!by $74,$06,$17,$e6,$d8,$e8,$f8,$28,$d7,$6a,$c6,$99,$a7,$da,$d8,$6c
	!by $b3,$45,$46,$26,$18,$28,$28,$67,$07,$99,$06,$c8,$e6,$1a,$18,$ab
	!by $53,$e4,$f5,$c5,$b7,$c7,$d7,$07,$b6,$49,$a5,$78,$86,$c9,$b7,$5b
	!by $e5,$77,$88,$58,$4a,$5a,$6a,$99,$49,$db,$38,$0b,$19,$5c,$4a,$dd
	!by $52,$e3,$e4,$c4,$b6,$c6,$c6,$06,$a5,$38,$a4,$67,$85,$b8,$b6,$4a
	!by $15,$a6,$b7,$87,$79,$89,$99,$c8,$78,$0b,$67,$3a,$48,$8b,$79,$1d
	!by $33,$c4,$c5,$a5,$97,$a7,$a7,$e6,$86,$19,$85,$48,$66,$99,$97,$3b
	!by $66,$f7,$09,$d8,$ca,$da,$da,$1a,$c9,$5c,$b8,$8b,$99,$dc,$ca,$6e
	!by $64,$f5,$f6,$d6,$c8,$d8,$d8,$18,$b7,$4a,$b6,$79,$97,$ca,$c8,$5c
	!by $f7,$89,$8a,$6a,$5c,$6c,$6c,$ab,$5b,$dd,$4a,$1d,$3b,$6e,$5c,$ff

	!by $00,$61,$e1,$72,$91,$b1,$82,$b3,$33,$13,$35,$15,$f5,$96,$47,$f7
	!by $61,$d2,$53,$d3,$f2,$13,$e3,$15,$94,$84,$96,$86,$67,$f7,$b8,$69
	!by $e1,$53,$d3,$54,$73,$93,$64,$95,$15,$05,$17,$07,$e7,$78,$39,$e9
	!by $72,$d3,$54,$e4,$04,$24,$f4,$26,$a5,$85,$a7,$87,$68,$09,$b9,$6a
	!by $91,$f2,$73,$04,$23,$43,$14,$45,$c4,$a4,$c6,$a6,$87,$28,$d8,$89
	!by $b1,$13,$93,$24,$43,$63,$34,$65,$e4,$c4,$e6,$c6,$a7,$48,$f8,$a9
	!by $82,$e3,$64,$f4,$14,$34,$05,$36,$b5,$95,$b7,$97,$78,$19,$c9,$7a
	!by $b3,$15,$95,$26,$45,$65,$36,$67,$e6,$c6,$e8,$c8,$a9,$4a,$fa,$ab
	!by $33,$94,$15,$a5,$c4,$e4,$b5,$e6,$66,$46,$68,$48,$29,$c9,$7a,$2b
	!by $13,$84,$05,$85,$a4,$c4,$95,$c6,$46,$36,$48,$38,$19,$a9,$6a,$1b
	!by $35,$96,$17,$a7,$c6,$e6,$b7,$e8,$68,$48,$6a,$4a,$2b,$cb,$7c,$2d
	!by $15,$86,$07,$87,$a6,$c6,$97,$c8,$48,$38,$4a,$3a,$1b,$ab,$6c,$1d
	!by $f5,$67,$e7,$68,$87,$a7,$78,$a9,$29,$19,$2b,$1b,$fb,$8c,$4d,$df
	!by $96,$f7,$78,$09,$28,$48,$19,$4a,$c9,$a9,$cb,$ab,$8c,$2d,$dd,$8e
	!by $47,$b8,$39,$b9,$d8,$f8,$c9,$fa,$7a,$6a,$7c,$6c,$4d,$dd,$9e,$4f
	!by $f7,$69,$e9,$6a,$89,$a9,$7a,$ab,$2b,$1b,$2d,$1d,$df,$8e,$4f,$ff

	!by $00,$55,$00,$72,$e1,$05,$d0,$b3,$27,$73,$42,$15,$95,$b2,$54,$f7
	!by $55,$ba,$65,$c7,$47,$6a,$26,$09,$7c,$c8,$97,$7a,$fa,$08,$b9,$5d
	!by $00,$65,$10,$72,$f1,$15,$d0,$b3,$27,$73,$42,$25,$a5,$b2,$64,$08
	!by $72,$c7,$72,$e4,$54,$77,$43,$26,$99,$e5,$b4,$87,$08,$25,$c6,$6a
	!by $e1,$47,$f1,$54,$d3,$f6,$b2,$95,$09,$55,$24,$07,$87,$94,$46,$e9
	!by $05,$6a,$15,$77,$f6,$1a,$d5,$b8,$2c,$78,$47,$2a,$aa,$b7,$69,$0d
	!by $d0,$26,$d0,$43,$b2,$d5,$a1,$84,$f7,$44,$13,$e5,$66,$83,$25,$c8
	!by $b3,$09,$b3,$26,$95,$b8,$84,$67,$da,$27,$f5,$c8,$49,$66,$08,$ab
	!by $27,$7c,$27,$99,$09,$2c,$f7,$da,$4e,$9a,$69,$3c,$bc,$d9,$7b,$1f
	!by $73,$c8,$73,$e5,$55,$78,$44,$27,$9a,$e6,$b5,$88,$09,$26,$c7,$6b
	!by $42,$97,$42,$b4,$24,$47,$13,$f5,$69,$b5,$84,$57,$d7,$f4,$96,$3a
	!by $15,$7a,$25,$87,$07,$2a,$e5,$c8,$3c,$88,$57,$3a,$ba,$c7,$79,$1d
	!by $95,$fa,$a5,$08,$87,$aa,$66,$49,$bc,$09,$d7,$ba,$3b,$48,$f9,$9d
	!by $b2,$08,$b2,$25,$94,$b7,$83,$66,$d9,$26,$f4,$c7,$48,$65,$07,$aa
	!by $54,$b9,$64,$c6,$46,$69,$25,$08,$7b,$c7,$96,$79,$f9,$07,$b8,$5c
	!by $f7,$5d,$08,$6a,$e9,$0d,$c8,$ab,$1f,$6b,$3a,$1d,$9d,$aa,$5c,$ff

palbuffer	!fill 768		; buffer to reset values after use

; --------------------------------------- Screenlist

mrendlst	!by 0
	!by 8,15,12,9
	!by $91
	!wo 0
	!scr "M65 Render",0

thgad	!by 10,15,12,3,$c9
	!wo evtrhires
	!scr "True Hires",0

tmgad	!by 12,15,12,3,$cb
	!wo evtrmulti
	!scr "True Multi",0

leave	!by 14,15,12,3,$cb
	!wo evleave
	!scr "Leave",0

	!by $80

; --------------------------------------- No Mega65! List

nomegalst	!by 0
	!by 8,14,12,10,$81,0,0
	!scr "M65 Render",0
	!by 15,19,7,3,$cd
	!wo evleave
	!scr "Leave",0

	!by $c0,10,16,6
	!scr "Only a",0
	!by $c0,11,16,6
	!scr "Mega65",0
	!by $c0,12,15,8
	!scr "will do!",0

	!by $80

; ---------------------------------------

modend	!eof
