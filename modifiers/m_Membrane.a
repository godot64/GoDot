
	!src <godotlib.lib>
	*= $c000
	!ct pet
;	!sl "labels.txt"

; ------------------------------------------------------------
;
; mod.Membrane
; Module to fill a mask with patterns which can be used as filters to affect colors
;
;   1.00, 24.07.19: first release
;   1.01, 04.09.21: added option to create "scanlines"
;   1.02, 19.07.25: changed 12.5% multicolor pattern to: interweaved
;   1.03, 14.06.26: added upside down patterns for 12.5% and 25%
;
; ------------------------------------------

	jmp start
	!by $20
	!wo 0
	!wo modend
	!wo 0
	!pet "Make Membranes  "
	!pet "1.03"
	!pet "14.06.26"
	!pet "A. Dettke       "

; ------------------------------------------

	dst	= $30	; /$31
	xbuf	= $32
	ybuf	= $33
	merk	= $34

	zeile	= sc_merk

	hup	= gr_pattern+8
	upside	= gr_pattern+40
	mup	= gr_pattern+64
	downside	= gr_pattern+96

	rendered	= $2000

; --------------------------------------- Main

start 	ldx sc_screenvek	; save current screenlist (mainlst)
	stx list
	ldx sc_screenvek+1
	stx list+1
	lda gr_redisp	; save current rendermode
	sta redisp
	jsr makepats
	jsr makechr
	jsr showreq	; show requester
	jmp gd_eloop	; wait for clicks

; --------------------------------------- Event: Exit

evexit	jsr makepats
	sec		; leave module
	rts

; ----------------------------------------- Event: Revert

evrevert	ldx #111
-	lda gr_pattern,x
	eor #$ff
	sta gr_pattern,x
	dex
	bpl -
	lda reverted
	beq +
	inx
+	stx reverted
	txa
	beq +
	lda #"1"		; Prozentanzeige anpassen:
	ldx #"0"		; 100% statt 0%
	sta all
	stx all+1
	lda #"7"		; 87.5% statt 12.5%
	ldx #"8"
	bne ++
+	lda #" "		; 0% statt 100%
	sta all
	sta all+1
	lda #"2"		; 12.5% statt 87.5%
	ldx #"1"
++	stx eight		; 25% statt 75% und umgekehrt
	sta eight+1
	sta four
	jmp showreq

; ----------------------------------------- Event: Switch Mode

evmode: 	ldx mode		; Mode: Hires/Multi umstellen
	inx
	cpx #2
	bcc md0
	ldx #0
md0	stx mode
	ldy mdoffs,x
	ldx #6
md1	lda modetxt,y
	sta mdtx,x
	dey
	dex
	bpl md1

	ldx #7
-	lda mode		; Grafikmodus (Pattern austauschen):
	beq +
	ldy #4		; gegen Multi
	!by $2c
+	ldy #0		; gegen Hires
	lda mdpats,y
	sta mod0,x
	iny
	lda mdpats,y
	sta mod1,x
	iny
	lda mdpats,y
	sta mod2,x
	iny
	lda mdpats,y
	sta mod3,x
	dex
	bpl -

	ldx #<mdtx	; zeigen
	ldy #>mdtx
	jsr gd_xtxout2
	jmp showreq

; ------------------------------------------ Event: Apply Pattern

evapply	lda strength	; chose pattern line (# in .a) from membpats
	asl
	asl
	asl
	ldx mode		; hires or multi?
	beq +
	clc
	adc #56		; if multi: add 56 as offset
+	sta xbuf

	lda #<1000	; 1000 Bytes ändern
	sta ls_vekta8
	lda #>1000
	sta ls_vekta8+1
	lda #<rendered	; ab $2000
	sta dst
	lda #>rendered
	sta dst+1

--	ldx xbuf		; Grafik-Screen füllen
	ldy #0
-	lda gr_pattern,x
	sta (dst),y
	inx
	iny
	cpy #8
	bne -
	jsr count
	beq +
	clc
	lda dst
	adc #8
	sta dst
	bcc --
	inc dst+1
	bne --
+	jmp evview	; und anzeigen

; ------------------------------------------ Events: Set Strength

evplain	ldy #0		; 0% (empty pattern)
	!by $2c
eveighth	ldy #1		; 12.5%
	!by $2c
evquarter	ldy #2		; 25%
	!by $2c
evhalf	ldy #3		; 50%
	!by $2c
evscnlne	ldy #4		; scanlines
	sty strength
	jmp indicate

; ------------------------------------------ Event: Turn Pattern upside down

evupdown	jsr tupsdwn	; toggle patterns
	ldx upsdwn	; flag: turn pattern upside down (1) or not (0)
	beq +
	ldx #$ff
+	inx
	stx upsdwn
	lda strength	; keep pointer arrow in its row
	asl
	clc
	adc #8
	sta zeile
	jmp showreq	; show (up/dwn) arrow (on the appropriate row)

; ------------------------------------------ Event: View

evview	jsr view		; switch graphics on (returns .y=0)

	lda #0
	sta sc_keyprs
	sta sc_stop
kl	lda sc_stop
	ora sc_keyprs	; wait for key
	beq kl

 	jsr rp2		; switch text mode on, display main screenlist
	lda redisp	; restore render mode
	sta gr_redisp

; --------------------------------------- Show Requester

showreq	ldx #<memblst	; display Membrane requester
	ldy #>memblst
	jsr gd_screen
	jsr clear		; clear arrow columns
	lda strength
	sta ybuf
sr2	jsr showind	; and show arrow again
	clc
	rts

; --------------------------------------- Kringel/Arrow definieren

makechr	ldx #7
-	lda chschr,x
	sta sc_undochar,x		; $df
	lda darrow,x
	sta sc_undochar+168,x	; $ee
	dex
	bpl -
	rts

; ------------------------------------------ Redisplay routines

; ---------------------------------------- Switch Graphics/Text

view:	ldx #1		; set fake redisp flag (allow redisplay)
	stx gr_redisp

	ldy #251
	lda #$f0		; ink: lgrey, paper: black
red0	sta $03ff,y
	sta $04f9,y
	sta $05f3,y
	sta $06ed,y
	dey
	bne red0

	lda #$1b		; hires graphics on
	sta $d018
	lda #$3b
	sta $d011
	lda gr_redisp 	; leave if flag set
	bne rp3

rp2:	jsr tmode		; text mode on
	ldx list		; show main screen
	ldy list+1
	jsr gd_screen
rp3:	clc
	rts

tmode:	ldx #$13		; back to text mode (graphics off)
	lda #$1b
	stx $d018
	sta $d011
	lda #$08
	sta $d016
	rts

; --------------------------------------- Counters

count 	lda ls_vekta8	; decrement ls_vekta8/9 by 1
	bne cou7
	dec ls_vekta8+1
cou7 	dec ls_vekta8
	lda ls_vekta8	; and check if 0 (sets .e)
	ora ls_vekta8+1
	rts

; ------------------------------------------ Toggle to new navi icons

makepats:	ldx #119
mn0:	lda gr_pattern,x	; buffer all syspattern (chars 224 to 238)
	ldy membpats,x
	sta membpats,x
	tya
	sta gr_pattern,x
	dex
	bpl mn0
	rts

; ------------------------------------------ Toggle UpsideDown Patterns

tupsdwn	ldx #15
mn1:	lda hup,x
	ldy upside,x	; exchange hires
	sta upside,x
	tya
	sta hup,x
	dex
	bpl mn1
mn2:	inx
	lda mup,x
	ldy downside,x	; and multi patterns
	sta downside,x
	tya
	sta mup,x
	cpx #15
	bcc mn2
	rts

; ------------------------------------------ Show Indicator Arrow

indicate	lda #32		; statt Pfeil: Leerzeichen
	sta indicator+1
	sty ybuf		; .y: aktuelle Zeile (merken)
	ldx #4
	stx xbuf
-	lda xbuf		; löschen (alle Positionen von unten nach oben)
	jsr rep
	dec xbuf
	bpl -

showind	lda upsdwn	; upside down aktiviert?
	beq +		; nein, skip
	lda strength	; ja, Pfeil zu weit oben?
	beq +
	cmp #3		; oder zu weit unten?
	bcs +		; wenn ja, skip

	lda #$ee		; sonst: Doppelpfeil holen
	!by $2c
+	lda #$5e		; Pfeil holen
	sta indicator+1
	lda ybuf		; Position holen: Zeile

rep	ldy #2		; Breite
	ldx #18		; Spalte
	asl
	sta merk
	clc
	lda #8		; Zeile (startet mit 16)
	adc merk
rep2	jsr gd_setpar
	jsr gd_initmove
	ldx #<indicator	; Pfeil ausgeben
	ldy #>indicator
	jmp gd_xtxout2

; ------------------------------------------ Clear UpsideDown Gadget

clear	lda indicator+1	; Arrow retten
	pha
	lda #32		; ebenso statt Pfeil: Leerzeichen
	sta indicator+1
	sty ybuf		; .y: aktuelle Position (merken)
	lda #9		; Zeile
	sta xbuf
-	ldx #18		; Spalte
	ldy #2		; Breite
	jsr rep2		; löschen von Zeile 9 bis 13
	inc xbuf
	lda xbuf
	cmp #14
	bcc -
	pla
	sta indicator+1	; Arrow zurück
	rts

; ------------------------------------------ Data

list	!wo 0
redisp 	!by 0
indicator	!by $20,$5e,0			; r-arrow
mode	!by 0
modetxt	!scr $df," Hires",$df," Multi"
mdoffs	!by 6,13
mdpats	!by $e0,$e1,$e2,$e3
	!by $e7,$e8,$e9,$ea
strength	!by 3
upsdwn	!by 0
reverted	!by 0

chschr	!by $00,$3a,$46,$4e,$40,$40,$3c,$00	; char $df

membpats	!by $00,$00,$00,$00,$00,$00,$00,$00	; hires:   0%
	!by $88,$00,$22,$00,$88,$00,$22,$00	;       12,5%
	!by $88,$22,$88,$22,$88,$22,$88,$22	;         25%
	!by $aa,$55,$aa,$55,$aa,$55,$aa,$55	;         50%
	!by $00,$ff,$00,$ff,$00,$ff,$00,$ff	; scanlines
	!by $00,$44,$00,$11,$00,$44,$00,$11	;       12,5% upside down
	!by $44,$11,$44,$11,$44,$11,$44,$11	;         25%

	!by $00,$00,$00,$00,$00,$00,$00,$00	; multi:   0%
	!by $cc,$00,$00,$00,$33,$00,$00,$00	;       12,5% ### 1.02
	!by $cc,$00,$33,$00,$cc,$00,$33,$00	;         25%
	!by $cc,$33,$cc,$33,$cc,$33,$cc,$33	;         50%
	!by $00,$ff,$00,$ff,$00,$ff,$00,$ff	; scanlines
	!by $00,$00,$00,$cc,$00,$00,$00,$33	;       12,5%
	!by $00,$cc,$00,$33,$00,$cc,$00,$33	;         25%

darrow	!by $08,$14,$36,$14,$14,$36,$14,$08	; char $fe

; --------------------------------------- Screenlist

memblst	!by 0
	!by 3,11,19,19,$81
	!wo 0
	!scr "Generate Membrane@"
	!by 9,18,3,5,$40
	!wo evupdown
	!by 7,20,10,3,$cd
	!wo evplain
mod0	!by $e0,$e0,$e0,$e0,$e0,$e0,$e0,$e0,0
	!by 9,20,10,3,$ce
	!wo eveighth
mod1	!by $e1,$e1,$e1,$e1,$e1,$e1,$e1,$e1,0
	!by 11,20,10,3,$ce
	!wo evquarter
mod2	!by $e2,$e2,$e2,$e2,$e2,$e2,$e2,$e2,0
	!by 13,20,10,3,$ce
	!wo evhalf
mod3	!by $e3,$e3,$e3,$e3,$e3,$e3,$e3,$e3,0
	!by 15,20,10,3,$ce
	!wo evscnlne
	!by $eb,$eb,$eb,$eb,$eb,$eb,$eb,$eb,0
	!by 17,11,6,3,$c7
	!wo evrevert
	!scr "Rvrt",0
	!by 17,17,6,3,$c0
	!wo evview
	!scr "View",0
	!by 17,23,7,3,$ce
	!wo evapply
	!scr "Apply",0
	!by 19,11,10,3,$c7
	!wo evmode
mdtx	!scr $df," Hires ",0
	!by 19,21,9,3,$ce
	!wo evexit
	!scr " Leave ",0

	!by $c0,5,11,8
	!scr "Opacity:",0
	!by $c0,5,20,8
	!scr "Pattern:",0
	!by $c0,7,13,4
all	!scr "  0%",0
	!by $c0,9,12,5
eight	!scr "12.5%",0
	!by $c0,11,14,3
four	!scr "25%",0
	!by $c0,13,14,3
	!scr "50%",0
	!by $c0,15,11,6
	!scr "Scnlns",0
	!by $80

; ---------------------------------------

modend	!eof